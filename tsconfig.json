{
  "compilerOptions": {
    "target": "ES2023",
    "module": "EsNext",
    "moduleResolution": "bundler",
    "rootDir": "./src",
    "outDir": "./dist",

    "strict": true,
    "esModuleInterop": true,
   
   
    "forceConsistentCasingInFileNames": true,
    "allowSyntheticDefaultImports": true,

    "skipLibCheck": true
  },
  "include": ["src/**/*"],
  "exclude": ["src/generated/**/*"]
}
